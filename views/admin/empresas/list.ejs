<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Empresas</h2>
    <a href="/admin/empresas/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nueva Empresa
    </a>
  </div>

  <% if (success_msg) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>
  
  <% if (error_msg) { %>
    <div class="alert alert-danger"><%= error_msg %></div>
  <% } %>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Razón Social</th>
          <th>RFC</th>
          <th>Contacto</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% empresas.forEach(empresa => { %>
          <tr>
            <td>
              <strong><%= empresa.razon_social %></strong><br>
              <small class="text-muted"><%= empresa.nombre_comercial %></small>
            </td>
            <td><%= empresa.rfc || 'N/A' %></td>
            <td>
              <%= empresa.telefono_contacto || 'N/A' %><br>
              <%= empresa.email_contacto || 'N/A' %>
            </td>
            <td>
              <a href="/admin/empresas/edit/<%= empresa.pk_empresa %>" 
                 class="btn btn-sm btn-info" title="Editar">
                <i class="fas fa-edit"></i>
              </a>
              <button class="btn btn-sm btn-danger delete-empresa" 
                      data-id="<%= empresa.pk_empresa %>" title="Eliminar">
                <i class="fas fa-trash-alt"></i>
              </button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
// Script para manejar la eliminación
document.querySelectorAll('.delete-empresa').forEach(btn => {
  btn.addEventListener('click', function() {
    const empresaId = this.getAttribute('data-id');
    if (confirm('¿Está seguro de eliminar esta empresa?')) {
      fetch(`/admin/empresas/delete/${empresaId}`, {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          window.location.reload();
        } else {
          alert(data.message || 'Error al eliminar la empresa');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error al eliminar la empresa');
      });
    }
  });
});
</script>