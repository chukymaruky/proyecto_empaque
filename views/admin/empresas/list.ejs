<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Empresas</h2>
    <a href="/admin/empresas/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nueva Empresa
    </a>
  </div>

  <!-- Filtros de búsqueda -->
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-search"></i></span>
        <input type="text" id="searchInput" class="form-control" placeholder="Buscar por nombre comercial...">
      </div>
    </div>
    <div class="col-md-6">
      <select id="empaqueFilter" class="form-select">
        <option value="">Todos los empaques</option>
        <% if (empaques && empaques.length) { %>
          <% empaques.forEach(empaque => { %>
            <option value="<%= empaque.pk_empaque %>"><%= empaque.nombre_empaque %></option>
          <% }); %>
        <% } %>
      </select>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Razón Social</th>
          <th>RFC</th>
          <th>Contacto</th>
          <th>Empaque</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="empresasTableBody">
        <% empresas.forEach(empresa => { %>
          <tr data-nombre-comercial="<%= empresa.nombre_comercial.toLowerCase() %>" 
              data-empaque="<%= empresa.fk_empaque || '' %>">
            <td>
              <strong><%= empresa.razon_social %></strong><br>
              <small class="text-muted"><%= empresa.nombre_comercial %></small>
            </td>
            <td><%= empresa.rfc || 'N/A' %></td>
            <td>
              <%= empresa.telefono_contacto || 'N/A' %><br>
              <%= empresa.email_contacto || 'N/A' %>
            </td>
            <td>
              <% if (empresa.fk_empaque && empaquesMap && empaquesMap[empresa.fk_empaque]) { %>
                <%= empaquesMap[empresa.fk_empaque].nombre_empaque %>
              <% } else { %>
                N/A
              <% } %>
            </td>
            <td>
              <a href="/admin/empresas/edit/<%= empresa.pk_empresa %>" 
                 class="btn btn-sm btn-info" title="Editar">
                <i class="fas fa-edit"></i>
              </a>
              <button class="btn btn-sm btn-danger delete-empresa" 
                      data-id="<%= empresa.pk_empresa %>" title="Eliminar">
                <i class="fas fa-trash-alt"></i>
              </button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
// Script para manejar la eliminación
document.querySelectorAll('.delete-empresa').forEach(btn => {
  btn.addEventListener('click', function() {
    const empresaId = this.getAttribute('data-id');
    if (confirm('¿Está seguro de eliminar esta empresa?')) {
      fetch(`/admin/empresas/delete/${empresaId}`, {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json',
        }
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          window.location.reload();
        } else {
          alert(data.message || 'Error al eliminar la empresa');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error al eliminar la empresa');
      });
    }
  });
});

// Funcionalidad de búsqueda y filtrado
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('searchInput');
  const empaqueFilter = document.getElementById('empaqueFilter');
  const empresasRows = document.querySelectorAll('#empresasTableBody tr');

  function filterEmpresas() {
    const searchTerm = searchInput.value.toLowerCase();
    const selectedEmpaque = empaqueFilter.value;
    
    empresasRows.forEach(row => {
      const nombreComercial = row.getAttribute('data-nombre-comercial');
      const empaqueId = row.getAttribute('data-empaque');
      
      const matchesSearch = nombreComercial.includes(searchTerm);
      const matchesEmpaque = !selectedEmpaque || empaqueId === selectedEmpaque;
      
      if (matchesSearch && matchesEmpaque) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }

  searchInput.addEventListener('input', filterEmpresas);
  empaqueFilter.addEventListener('change', filterEmpresas);
});
</script>