<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Clientes</h2>
    <a href="/admin/clientes/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Cliente
    </a>
  </div>

 

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Razón Social</th>
          <th>Nombre Comercial</th>
          <th>RFC</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (clientes.length === 0) { %>
          <tr>
            <td colspan="4" class="text-center">No hay clientes registrados</td>
          </tr>
        <% } %>
        
        <% clientes.forEach(cliente => { %>
          <tr>
            <td><%= cliente.razon_social %></td>
            <td><%= cliente.nombre_comercial || 'N/A' %></td>
            <td><%= cliente.rfc || 'N/A' %></td>
            <td>
              <a href="#" class="btn btn-sm btn-info">
                <i class="fas fa-eye"></i> Ver
              </a>
              <form action="/admin/clientes/delete/<%= cliente.pk_cliente %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Eliminar este cliente?')">
                  <i class="fas fa-trash-alt"></i> Eliminar
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>