<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Clientes</h2>
    <a href="/admin/clientes/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Cliente
    </a>
  </div>

  <!-- Filtros de búsqueda y empaque -->
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-search"></i></span>
        <input type="text" id="searchInput" class="form-control" placeholder="Buscar por razón social, nombre comercial o RFC...">
      </div>
    </div>
    <div class="col-md-6">
      <select id="empaqueFilter" class="form-select">
        <option value="">Todos los empaques</option>
        <% 
          // Obtener empaques únicos de los clientes
          const empaquesUnicos = [];
          clientes.forEach(cliente => {
            if (cliente.fk_empaque && !empaquesUnicos.some(e => e.fk_empaque === cliente.fk_empaque)) {
              empaquesUnicos.push({ fk_empaque: cliente.fk_empaque, nombre_empaque: cliente.nombre_empaque });
            }
          });
        %>
        <% empaquesUnicos.forEach(empaque => { %>
          <option value="<%= empaque.fk_empaque %>"><%= empaque.nombre_empaque %></option>
        <% }); %>
      </select>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>ID</th>
          <th>Razón Social</th>
          <th>Nombre Comercial</th>
          <th>RFC</th>
          <th>Empresa</th>
          <th>Empaque</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (clientes.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center">No hay clientes registrados</td>
          </tr>
        <% } %>
        
        <% clientes.forEach(cliente => { %>
          <tr data-search="<%= `${cliente.razon_social} ${cliente.nombre_comercial} ${cliente.rfc}`.toLowerCase() %>" 
              data-empaque="<%= cliente.fk_empaque %>">
            <td><%= cliente.pk_cliente %></td>
            <td><%= cliente.razon_social %></td>
            <td><%= cliente.nombre_comercial || 'N/A' %></td>
            <td><%= cliente.rfc || 'N/A' %></td>
            <td><%= cliente.nombre_empresa %></td>
            <td><%= cliente.nombre_empaque %></td>
            <td>
              <a href="/admin/clientes/edit/<%= cliente.pk_cliente %>" class="btn btn-sm btn-info" title="Editar">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/admin/clientes/delete/<%= cliente.pk_cliente %>" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Estás seguro de eliminar este cliente?')"
                        title="Eliminar">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('searchInput');
  const empaqueFilter = document.getElementById('empaqueFilter');
  const rows = document.querySelectorAll('tbody tr');

  function filterClientes() {
    const searchTerm = searchInput.value.toLowerCase();
    const selectedEmpaque = empaqueFilter.value;
    
    rows.forEach(row => {
      const searchData = row.getAttribute('data-search');
      const empaqueId = row.getAttribute('data-empaque');
      
      const matchesSearch = searchData && searchData.includes(searchTerm);
      const matchesEmpaque = !selectedEmpaque || empaqueId === selectedEmpaque;
      
      if (matchesSearch && matchesEmpaque) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }

  searchInput.addEventListener('input', filterClientes);
  empaqueFilter.addEventListener('change', filterClientes);
});
</script>