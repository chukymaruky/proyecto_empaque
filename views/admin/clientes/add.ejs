<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <h2>Agregar Nuevo Cliente</h2>
  

  <form method="POST" action="/admin/clientes/add">
    <div class="mb-3">
      <label for="empresa_id" class="form-label">Seleccione una Empresa *</label>
      <select class="form-select" id="empresa_id" name="empresa_id" required>
        <option value="">Seleccione una empresa...</option>
        <% empresas.forEach(empresa => { %>
          <option value="<%= empresa.pk_empresa %>">
            <%= empresa.razon_social %> 
            <% if (empresa.nombre_comercial) { %>
              (<%= empresa.nombre_comercial %>)
            <% } %>
          </option>
        <% }); %>
      </select>
    </div>

    <% if (user && user.rol === 'administrador' && Array.isArray(empaques) && empaques.length > 0) { %>
    <div class="mb-3">
      <label for="empaque_id" class="form-label">Seleccione un Empaque *</label>
      <select class="form-select" id="empaque_id" name="empaque_id" required>
        <option value="">Seleccione un empaque...</option>
        <% empaques.forEach(empaque => { %>
          <option value="<%= empaque.pk_empaque %>">
            <%= empaque.nombre_empaque %>
          </option>
        <% }); %>
      </select>
    </div>
    <% } %>
    
    <button type="submit" class="btn btn-primary">Registrar Cliente</button>
    <a href="/admin/clientes" class="btn btn-secondary">Cancelar</a>
  </form>
</div>

<script>
// Validación en cliente
document.querySelector('form').addEventListener('submit', function(e) {
  const empresaSelect = document.getElementById('empresa_id');
  const empaqueSelect = document.getElementById('empaque_id');
  
  if (empresaSelect.value === '') {
    e.preventDefault();
    alert('Debe seleccionar una empresa');
    empresaSelect.focus();
    return;
  }
  
  if (empaqueSelect && empaqueSelect.value === '') {
    e.preventDefault();
    alert('Debe seleccionar un empaque');
    empaqueSelect.focus();
  }
});
</script>