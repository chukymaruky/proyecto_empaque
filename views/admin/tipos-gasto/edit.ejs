<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <h2>Editar Tipo de Gasto</h2>
  
  <% if (error_msg) { %>
    <div class="alert alert-danger"><%= error_msg %></div>
  <% } %>
  
  <% if (success_msg) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>

  <form method="POST" action="/admin/tipos-gasto/edit/<%= tipoGasto.pk_tipo_gasto %>" id="tipoGastoForm">
    <div class="mb-3">
      <label for="tipo_gasto" class="form-label">Nombre del Tipo de Gasto *</label>
      <input type="text" class="form-control" id="tipo_gasto" name="tipo_gasto" required
             value="<%= tipoGasto.tipo_gasto %>"
             placeholder="Ej: Combustible, Mantenimiento, etc.">
    </div>

    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
      <button type="submit" class="btn btn-primary">Actualizar Tipo de Gasto</button>
      <a href="/admin/tipos-gasto" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Validación del formulario
  document.getElementById('tipoGastoForm').addEventListener('submit', function(e) {
    const tipoGastoInput = document.getElementById('tipo_gasto');
    
    if (!tipoGastoInput.value.trim()) {
      e.preventDefault();
      tipoGastoInput.classList.add('is-invalid');
      alert('El nombre del tipo de gasto es obligatorio');
    } else {
      tipoGastoInput.classList.remove('is-invalid');
    }
  });
});
</script>