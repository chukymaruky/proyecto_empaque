<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <h2>Registrar Venta de Producto</h2>
  
  <% if (error_msg) { %>
    <div class="alert alert-danger"><%= error_msg %></div>
  <% } %>
  
  <% if (success_msg) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>

  <form method="POST" action="/admin/ventas-productos/add" id="ventaForm">
    <div class="row">
      <div class="col-md-6">
        <div class="mb-3">
          <label for="producto_id" class="form-label">Producto *</label>
          <select class="form-select" id="producto_id" name="producto_id" required>
            <option value="">Seleccione un producto...</option>
            <% productos.forEach(producto => { %>
              <option value="<%= producto.pk_producto_procesado %>">
                <%= producto.nombre_categoria %>
              </option>
            <% }); %>
          </select>
        </div>

        <div class="mb-3">
          <label for="tipo_unidad_id" class="form-label">Tipo de Unidad *</label>
          <select class="form-select" id="tipo_unidad_id" name="tipo_unidad_id" required>
            <option value="">Seleccione un tipo de unidad...</option>
            <% tiposUnidad.forEach(tipo => { %>
              <option value="<%= tipo.pk_tipo_unidad %>">
                <%= tipo.nombre_tipo_unidad %>
              </option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="col-md-6">
        <div class="mb-3">
          <label for="cliente_id" class="form-label">Cliente *</label>
          <select class="form-select" id="cliente_id" name="cliente_id" required>
            <option value="">Seleccione un cliente...</option>
            <% clientes.forEach(cliente => { %>
              <option value="<%= cliente.pk_cliente %>">
                <%= cliente.razon_social || cliente.nombre_comercial %>
              </option>
            <% }); %>
          </select>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6">
        <div class="mb-3">
          <label for="cantidad" class="form-label">Cantidad *</label>
          <input type="number" step="0.01" class="form-control" 
                 id="cantidad" name="cantidad" min="0.01" required>
        </div>
      </div>

      <div class="col-md-6">
        <div class="mb-3">
          <label for="precio" class="form-label">Precio Unitario *</label>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <input type="number" step="0.01" class="form-control" 
                   id="precio" name="precio" min="0.01" required>
          </div>
        </div>
      </div>
    </div>

    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
      <button type="submit" class="btn btn-primary">Registrar Venta</button>
      <a href="/admin/ventas-productos" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Validación del formulario
  document.getElementById('ventaForm').addEventListener('submit', function(e) {
    let isValid = true;
    
    // Validar campos obligatorios
    const requiredFields = ['producto_id', 'tipo_unidad_id', 'cliente_id', 'cantidad', 'precio'];
    requiredFields.forEach(fieldId => {
      const field = document.getElementById(fieldId);
      if (!field.value) {
        isValid = false;
        field.classList.add('is-invalid');
      } else {
        field.classList.remove('is-invalid');
      }
    });

    // Validar que cantidad y precio sean números positivos
    const cantidad = parseFloat(document.getElementById('cantidad').value);
    const precio = parseFloat(document.getElementById('precio').value);
    
    if (isNaN(cantidad) || cantidad <= 0) {
      isValid = false;
      document.getElementById('cantidad').classList.add('is-invalid');
    } else {
      document.getElementById('cantidad').classList.remove('is-invalid');
    }
    
    if (isNaN(precio) || precio <= 0) {
      isValid = false;
      document.getElementById('precio').classList.add('is-invalid');
    } else {
      document.getElementById('precio').classList.remove('is-invalid');
    }
    
    if (!isValid) {
      e.preventDefault();
      alert('Complete todos los campos obligatorios correctamente');
    }
  });
});
</script>