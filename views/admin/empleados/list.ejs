<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Empleados</h2>
    <a href="/admin/empleados/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Empleado
    </a>
  </div>



  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Nombre</th>
          <th>Usuario</th>
          <th>Rol</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (empleados.length === 0) { %>
          <tr>
            <td colspan="4" class="text-center">No hay empleados registrados</td>
          </tr>
        <% } %>
        
        <% empleados.forEach(empleado => { %>
          <tr>
            <td><%= empleado.nombres %> <%= empleado.primer_apellido %></td>
            <td><%= empleado.nombre_usuario %></td>
            <td><%= empleado.rol %></td>
            <td>
              <a href="#" class="btn btn-sm btn-info">
                <i class="fas fa-eye"></i> Ver
              </a>
              <form action="/admin/empleados/delete/<%= empleado.pk_empleado %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Eliminar este empleado?')">
                  <i class="fas fa-trash-alt"></i> Eliminar
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>