<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Empleados</h2>
    <a href="/admin/empleados/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Empleado
    </a>
  </div>

  <!-- Filtros de búsqueda y empaque -->
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-search"></i></span>
        <input type="text" id="searchInput" class="form-control" placeholder="Buscar por nombre o usuario...">
      </div>
    </div>
    <div class="col-md-6">
      <select id="empaqueFilter" class="form-select">
        <option value="">Todos los empaques</option>
        <% if (Array.isArray(empaques) && empaques.length > 0) { %>
          <% empaques.forEach(empaque => { %>
            <option value="<%= empaque.pk_empaque %>">
              <%= empaque.nombre_empaque %>
            </option>
          <% }); %>
        <% } %>
      </select>
    </div>
  </div>


  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Nombre</th>
          <th>Usuario</th>
          <th>Rol</th>
          <th>Empaque</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (empleados.length === 0) { %>
          <tr>
            <td colspan="5" class="text-center">No hay empleados registrados</td>
          </tr>
        <% } %>
        
        <% empleados.forEach(empleado => { %>
          <tr data-search="<%= `${empleado.nombres} ${empleado.primer_apellido} ${empleado.nombre_usuario}`.toLowerCase() %>"
              data-empaque="<%= empleado.pk_empaque %>">
            <td><%= empleado.nombres %> <%= empleado.primer_apellido %></td>
            <td><%= empleado.nombre_usuario %></td>
            <td><%= empleado.rol %></td>
            <td><%= empleado.nombre_empaque %></td>
            <td>
              <form action="/admin/empleados/delete/<%= empleado.pk_empleado %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Eliminar este empleado?')">
                  <i class="fas fa-trash-alt"></i> Eliminar
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('searchInput');
  const empaqueFilter = document.getElementById('empaqueFilter');
  const rows = document.querySelectorAll('tbody tr');

  function filterEmpleados() {
    const searchTerm = searchInput.value.toLowerCase();
    const selectedEmpaque = empaqueFilter.value;
    
    rows.forEach(row => {
      const searchData = row.getAttribute('data-search');
      const empaqueId = row.getAttribute('data-empaque');
      
      const matchesSearch = searchData && searchData.includes(searchTerm);
      const matchesEmpaque = !selectedEmpaque || empaqueId === selectedEmpaque;
      
      if (matchesSearch && matchesEmpaque) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }

  searchInput.addEventListener('input', filterEmpleados);
  empaqueFilter.addEventListener('change', filterEmpleados);
});
</script>