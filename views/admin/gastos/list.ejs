<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Registro de Gastos</h2>
    <div>
      <a href="/admin/gastos/add" class="btn btn-success me-2">
        <i class="fas fa-plus"></i> Nuevo Gasto
      </a>
      <span class="badge bg-primary fs-6">
        Total: $<%= total %>
      </span>
    </div>
  </div>


  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Fecha</th>
          <th>Concepto</th>
          <th>Tipo</th>
          <th>Monto</th>
          <th>Pedido</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (gastos.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center">No hay gastos registrados</td>
          </tr>
        <% } %>
        
        <% gastos.forEach(gasto => { %>
          <tr>
            <td><%= new Date(gasto.fecha).toLocaleDateString() %></td>
            <td><%= gasto.concepto %></td>
            <td><%= gasto.tipo_gasto %></td>
            <td>$<%= parseFloat(gasto.monto).toFixed(2) %></td>
            <td>
              <% if (gasto.pk_pedido) { %>
                <a href="/admin/pedidos/<%= gasto.pk_pedido %>">#<%= gasto.pk_pedido %></a>
              <% } else { %>
                N/A
              <% } %>
            </td>
            <td>
              <a href="#" class="btn btn-sm btn-info">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/admin/gastos/delete/<%= gasto.pk_gasto %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Eliminar este gasto?')">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>