<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Tipos de Unidad</h2>
    <a href="/admin/tipos-unidad/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Tipo
    </a>
  </div>



  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>ID</th>
          <th>Tipo de Unidad</th>
          <th>Empaque</th>
          <th>Fecha Registro</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (tiposUnidad.length === 0) { %>
          <tr>
            <td colspan="5" class="text-center">No hay tipos de unidad registrados</td>
          </tr>
        <% } %>
        
        <% tiposUnidad.forEach(tipo => { %>
          <tr>
            <td><%= tipo.pk_tipo_unidad %></td>
            <td><%= tipo.nombre_tipo_unidad %></td>
            <td><%= tipo.nombre_empaque %></td>
            <td><%= new Date(tipo.fecha).toLocaleDateString() %></td>
            <td>
              <a href="/admin/tipos-unidad/edit/<%= tipo.pk_tipo_unidad %>" 
                 class="btn btn-sm btn-warning" title="Editar">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/admin/tipos-unidad/delete/<%= tipo.pk_tipo_unidad %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Estás seguro de eliminar este tipo de unidad?')"
                        title="Eliminar">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>