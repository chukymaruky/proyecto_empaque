<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Productos Procesados</h2>
    <a href="/admin/productos-procesados/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Producto
    </a>
  </div>

  

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Proveedor</th>
          <th>Categoría</th>
          <th>Tipo de Unidad</th>
          <th>Fecha Pedido</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (productos.length === 0) { %>
          <tr>
            <td colspan="5" class="text-center">No hay productos procesados registrados</td>
          </tr>
        <% } %>
        
        <% productos.forEach(producto => { %>
          <tr>
            <td><%= producto.proveedor_nombre %></td>
            <td><%= producto.nombre_categoria %></td>
            <td><%= producto.nombre_tipo_unidad %></td>
            <td><%= new Date(producto.fecha_pedido).toLocaleDateString() %></td>
            <td>
              <a href="/admin/productos-procesados/edit/<%= producto.pk_producto_procesado %>" 
                 class="btn btn-sm btn-warning" title="Editar">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/admin/productos-procesados/delete/<%= producto.pk_producto_procesado %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Estás seguro de eliminar este producto procesado?')"
                        title="Eliminar">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>