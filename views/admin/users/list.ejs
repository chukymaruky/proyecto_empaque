<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestión de Usuarios</h2>
    <a href="/admin/users/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Usuario
    </a>
  </div>

  <!-- Filtros de búsqueda -->
  <div class="row mb-4">
    <div class="col-md-6">
      <div class="input-group">
        <span class="input-group-text"><i class="fas fa-search"></i></span>
        <input type="text" id="searchInput" class="form-control" placeholder="Buscar por nombre o usuario...">
      </div>
    </div>
    <div class="col-md-6">
      <select id="empaqueFilter" class="form-select">
        <option value="">Todos los empaques</option>
        <% if (empaques && empaques.length) { %>
          <% empaques.forEach(empaque => { %>
            <option value="<%= empaque.pk_empaque %>">
              <%= empaque.nombre_empaque %>
            </option>
          <% }); %>
        <% } %>
      </select>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Usuario</th>
          <th>Nombre</th>
          <th>Rol</th>
          <th>Empaque</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="usersTableBody">
        <% if (users && users.length > 0) { %>
          <% users.forEach(user => { %>
            <tr data-nombre="<%= `${user.nombres} ${user.primer_apellido}`.toLowerCase() %>"
                data-usuario="<%= user.nombre_usuario.toLowerCase() %>"
                data-empaque="<%= user.fk_empaque || '' %>">
              <td><%= user.nombre_usuario %></td>
              <td><%= user.nombres %> <%= user.primer_apellido %></td>
              <td><%= user.rol %></td>
              <td><%= user.nombre_empaque %></td>
              <td>
                <a href="/admin/users/edit/<%= user.pk_usuario %>" class="btn btn-sm btn-info">
                  <i class="fas fa-edit"></i>
                </a>
                <form action="/admin/users/delete/<%= user.pk_usuario %>" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar este usuario?')">
                    <i class="fas fa-trash-alt"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="5" class="text-center">No hay usuarios registrados</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
// Funcionalidad de búsqueda y filtrado
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('searchInput');
  const empaqueFilter = document.getElementById('empaqueFilter');
  const usersRows = document.querySelectorAll('#usersTableBody tr');

  function filterUsers() {
    const searchTerm = searchInput.value.toLowerCase();
    const selectedEmpaque = empaqueFilter.value;
    
    usersRows.forEach(row => {
      const nombre = row.getAttribute('data-nombre');
      const usuario = row.getAttribute('data-usuario');
      const empaqueId = row.getAttribute('data-empaque');
      
      const matchesSearch = nombre.includes(searchTerm) || usuario.includes(searchTerm);
      const matchesEmpaque = !selectedEmpaque || empaqueId === selectedEmpaque;
      
      if (matchesSearch && matchesEmpaque) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }

  searchInput.addEventListener('input', filterUsers);
  empaqueFilter.addEventListener('change', filterUsers);
});
</script>