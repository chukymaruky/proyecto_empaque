<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Transportes</h2>
    <a href="/admin/transportes/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Transporte
    </a>
  </div>

  

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Placa</th>
          <th>Marca</th>
          <th>Color</th>
          <th>Tipo</th>
          <th>Empresa</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (transportes.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center">No hay transportes registrados</td>
          </tr>
        <% } %>
        
        <% transportes.forEach(transporte => { %>
          <tr>
            <td><%= transporte.numero_placa %></td>
            <td><%= transporte.marca %></td>
            <td><%= transporte.color %></td>
            <td><%= transporte.tipo_vehiculo %></td>
            <td><%= transporte.empresa_nombre || 'N/A' %></td>
            <td>
              <a href="/admin/transportes/edit/<%= transporte.pk_transporte %>" 
                 class="btn btn-sm btn-warning" title="Editar">
                <i class="fas fa-edit"></i>
              </a>
              <form action="/admin/transportes/delete/<%= transporte.pk_transporte %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Estás seguro de eliminar este transporte?')"
                        title="Eliminar">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>