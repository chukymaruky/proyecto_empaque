<%- include('../layouts/main') -%>

<div class="admin-dashboard">
  <h2>Panel de Administración</h2>
  
  <div class="admin-actions">
    <h3>Seleccionar Empaque</h3>
    <form action="/admin" method="GET">
      <select name="empaque_id" onchange="this.form.submit()">
        <option value="">-- Todos los empaques --</option>
        <% empaques.forEach(empaque => { %>
          <option value="<%= empaque.pk_empaque %>" 
            <%= selectedEmpaque && selectedEmpaque.pk_empaque === empaque.pk_empaque ? 'selected' : '' %>>
            <%= empaque.nombre_empaque %>
          </option>
        <% }); %>
      </select>
    </form>
  </div>



  <% if (selectedEmpaque) { %>
    <div class="empaque-info">
      <h3>Información del Empaque: <%= selectedEmpaque.nombre_empaque %></h3>
      <p>Fecha de creación: <%= selectedEmpaque.fecha.toLocaleDateString() %></p>
      <p>Estado: <%= selectedEmpaque.estado ? 'Activo' : 'Inactivo' %></p>
    </div>
  <% } %>
<br>
  <!-- Botón que controla el collapse -->
<p>
  <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAgregar"
    aria-expanded="false" aria-controls="collapseAgregar">
    Agregar Registros
  </button>
</p>

<!-- Contenido colapsable con list-group adentro -->
<div class="collapse" id="collapseAgregar">
  <div class="card card-body">
    <div class="list-group">
      <a href="/admin/empresas/add" class="list-group-item list-group-item-action">Agregar Empresa</a>
      <a href="/admin/proveedores/add" class="list-group-item list-group-item-action">Agregar Proveedor</a>
      <a href="/admin/users/add" class="list-group-item list-group-item-action">Agregar Usuario</a>
      <a href="#" class="list-group-item list-group-item-action">Agregar </a>
      <a href="#" class="list-group-item list-group-item-action">Agregar </a>
      <a href="#" class="list-group-item list-group-item-action">Agregar </a>
      <a href="#" class="list-group-item list-group-item-action">Agregar </a>
      <a href="#" class="list-group-item list-group-item-action">Agregar </a>
    </div>
  </div>
</div>
    
<br>
      <!-- Botón que controla el collapse -->
