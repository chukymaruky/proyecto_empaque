<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Pedidos</h2>
    <a href="/admin/pedidos/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Pedido
    </a>
  </div>


  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Proveedor</th>
          <th>Categoría</th>
          <th>Peso (kg)</th>
          <th>Fecha/Hora Llegada</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (pedidos.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center">No hay pedidos registrados</td>
          </tr>
        <% } %>
        
        <% pedidos.forEach(pedido => { %>
          <tr>
            <td><%= pedido.proveedor_nombre %></td>
            <td><%= pedido.categoria_nombre %></td>
            <td><%= pedido.peso_pedido %></td>
            <td><%= new Date(pedido.dia_hora_llegada).toLocaleString() %></td>
            <td>
              <% if (pedido.estado_pedido) { %>
                <span class="badge bg-warning">Pendiente</span>
              <% } else { %>
                <span class="badge bg-success">Entregado</span>
              <% } %>
            </td>
            <td>
              <a href="/admin/pedidos/view/<%= pedido.pk_pedido %>" class="btn btn-sm btn-info">
                <i class="fas fa-eye"></i> Ver
              </a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>