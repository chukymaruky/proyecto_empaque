<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Pedidos</h2>
    <a href="/admin/pedidos/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Pedido
    </a>
  </div>

  <div class="row mb-4">
    <div class="col-md-12">
      <form action="" method="GET" class="d-flex gap-2">
        <div class="flex-grow-1">
          <input 
            type="text" 
            name="search" 
            class="form-control" 
            placeholder="Buscar por proveedor, categoría..."
            value="<%= searchQuery %>"
          >
        </div>
        
        <% if (user.rol === 'administrador' && Array.isArray(empaques) && empaques.length > 0) { %>
          <div style="min-width: 200px;">
            <select name="empaque" class="form-select">
              <option value="">Todos los empaques</option>
              <% empaques.forEach(empaque => { %>
                <option value="<%= empaque.pk_empaque %>" 
                        <%= selectedEmpaque == empaque.pk_empaque ? 'selected' : '' %>>
                  <%= empaque.nombre_empaque %>
                </option>
              <% }); %>
            </select>
          </div>
        <% } %>
        
        <button type="submit" class="btn btn-primary">
          <i class="fas fa-search"></i> Buscar
        </button>
        
        <% if (searchQuery || selectedEmpaque) { %>
          <a href="/admin/pedidos" class="btn btn-secondary">
            <i class="fas fa-times"></i> Limpiar
          </a>
        <% } %>
      </form>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>Proveedor</th>
          <th>Categoría</th>
          <th>Peso (kg)</th>
          <th>Fecha/Hora Llegada</th>
          <th>Estado</th>
          <% if (user.rol === 'administrador') { %>
            <th>Empaque</th>
          <% } %>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% 
        // Filtrar pedidos según la búsqueda
        let filteredPedidos = pedidos;
        if (searchQuery) {
          const search = searchQuery.toLowerCase();
          filteredPedidos = pedidos.filter(pedido => 
            (pedido.proveedor_nombre || '').toLowerCase().includes(search) ||
            (pedido.categoria_nombre || '').toLowerCase().includes(search) ||
            (pedido.nombre_empaque || '').toLowerCase().includes(search)
          );
        }
        %>
        
        <% if (filteredPedidos.length === 0) { %>
          <tr>
            <td colspan="<%= user.rol === 'administrador' ? '7' : '6' %>" class="text-center">
              No hay pedidos registrados
            </td>
          </tr>
        <% } %>
        
        <% filteredPedidos.forEach(pedido => { %>
          <tr>
            <td><%= pedido.proveedor_nombre || 'N/A' %></td>
            <td><%= pedido.categoria_nombre %></td>
            <td><%= parseFloat(pedido.peso_pedido).toFixed(2) %></td>
            <td><%= new Date(pedido.dia_hora_llegada).toLocaleString() %></td>
            <td>
              <% if (pedido.estado_pedido) { %>
                <span class="badge bg-warning">Pendiente</span>
              <% } else { %>
                <span class="badge bg-success">Entregado</span>
              <% } %>
            </td>
            <% if (user.rol === 'administrador') { %>
              <td><%= pedido.nombre_empaque %></td>
            <% } %>
            <td>
              <div class="btn-group">
                <a href="/admin/pedidos/view/<%= pedido.pk_pedido %>" 
                   class="btn btn-sm btn-info" 
                   title="Ver detalles">
                  <i class="fas fa-eye"></i>
                </a>
                <a href="/admin/pedidos/edit/<%= pedido.pk_pedido %>" 
                   class="btn btn-sm btn-primary"
                   title="Editar pedido">
                  <i class="fas fa-edit"></i>
                </a>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>