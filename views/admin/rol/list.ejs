<%- include('../../layouts/adminLayout') -%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Listado de Roles</h2>
    <a href="/admin/roles/add" class="btn btn-success">
      <i class="fas fa-plus"></i> Nuevo Rol
    </a>
  </div>

  <% if (success_msg) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>
  <% if (error_msg) { %>
    <div class="alert alert-danger"><%= error_msg %></div>
  <% } %>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="thead-dark">
        <tr>
          <th>ID</th>
          <th>Nombre del Rol</th>
          <th>Empaque</th>
          <th>Fecha Registro</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (roles.length === 0) { %>
          <tr>
            <td colspan="5" class="text-center">No hay roles registrados</td>
          </tr>
        <% } %>
        
        <% roles.forEach(rol => { %>
          <tr>
            <td><%= rol.pk_rol %></td>
            <td><%= rol.rol %></td>
            <td><%= rol.nombre_empaque %></td>
            <td><%= new Date(rol.fecha).toLocaleDateString() %></td>
            <td>
              <form action="/admin/roles/delete/<%= rol.pk_rol %>" 
                    method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm btn-danger" 
                        onclick="return confirm('¿Estás seguro de eliminar este rol?')"
                        title="Eliminar">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>