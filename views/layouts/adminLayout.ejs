<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Sistema de Empaques</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.10.2/dist/umd/popper.min.js" integrity="sha384-O4xg1g5B5h5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5g5" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.min.js" integrity="sha384-QJHtvGhmr9XOIpI6YVutG+2QOK9T+ZnN4kzFN1RtK3zEFEIsxhlmWl5/YESvpZ13" crossorigin="anonymous"></script>
  <link rel="stylesheet" href="/css/admin.css">
  <script src="https://kit.fontawesome.com/6d5d0186ca.js" crossorigin="anonymous"></script>
</head>

<body>
  <!-- Barra de navegación -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/admin">Panel Admin</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav mr-auto">

          <li class="nav-item">
            <a class="nav-link" href="/admin/proveedores">Proveedores</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/empresas">Empresas</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/users">Usuarios</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/categorias">
              <i class="fas fa-tags"></i> Categorías
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/clientes">
              <i class="fas fa-users"></i> Clientes
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/empleados">
              <i class="fas fa-user-tie"></i> Empleados
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/gastos">
              <i class="fas fa-money-bill-wave"></i> Gastos
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/ventas">
              <i class="fas fa-truck"></i> pedidos
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/productos">
              <i class="fas fa-box-open"></i> prod. procesado
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/rol">
              <i class="fas fa-user-shield"></i> roles
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/salarios">
              <i class="fas fa-coins"></i> salarios
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/tipos-gasto">
              <i class="fas fa-list-alt"></i> Tipos de Gasto
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/tipos-unidad">
                <i class="fas fa-balance-scale"></i> Tipos de Unidades
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/tipos-vehiculo">
                <i class="fas fa-car"></i> Tipos de vehículos
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/transportes">
                <i class="fas fa-truck-moving"></i> Transportes
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/transportistas">
                <i class="fas fa-user-friends"></i> Transportistas
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/admin/ventas-productos">
                <i class="fas fa-shopping-cart"></i> ventas de productos
            </a>
          </li>



        </ul>
        <span class="navbar-text text-white mr-3">
          <%= user.username %> (<%= user.rol %>)
        </span>
        <a href="/logout" class="btn btn-outline-light">Cerrar sesión</a>
      </div>
    </div>
  </nav>

  <!-- Contenido principal -->
  <main class="container-fluid mt-4">
    <% if (typeof body !== 'undefined') { %>
    <%- body %>
    <% } else { %>
    <!-- Contenido por defecto si body no está definido -->

    <% } %>
  </main>

</body>

</html>